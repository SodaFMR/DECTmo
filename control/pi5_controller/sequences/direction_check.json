{
  "version": 1,
  "type": "motion.sequence",
  "id": "direction-check",
  "name": "Forward, backward, left, right check",
  "default_speed": 20,
  "wheel_mode": "ordinary",
  "steps": [
    {
      "action": "forward",
      "duration_ms": 250
    },
    {
      "action": "stop"
    },
    {
      "action": "backward",
      "duration_ms": 250
    },
    {
      "action": "stop"
    },
    {
      "action": "left",
      "duration_ms": 250
    },
    {
      "action": "stop"
    },
    {
      "action": "right",
      "duration_ms": 250
    },
    {
      "action": "stop"
    }
  ]
}
